<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2A1713"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="34dp"
        android:paddingBottom="42dp">

        <!-- BACK BUTTON -->
        <TextView
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="←"
            android:textSize="34sp"
            android:textColor="#FFE8A3"
            android:textStyle="bold" />

        <!-- HEADER -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Review\nYour Coffee"
                    android:textColor="#FFF3E5"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/productNameText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Latte"
                    android:textColor="#D9A54C"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Share your experience and help others discover great coffee."
                    android:textColor="#E8D7CE"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/reviewProductImage"
                android:layout_width="155dp"
                android:layout_height="135dp"
                android:layout_gravity="end|top"
                android:layout_marginEnd="-4dp"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <!-- RATING -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Overall Rating"
            android:textColor="#FFF3E5"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:id="@+id/starContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/star1"
                android:layout_width="52dp"
                android:layout_height="58dp"
                android:gravity="center"
                android:text="☆"
                android:textColor="#D8A46B"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/star2"
                android:layout_width="52dp"
                android:layout_height="58dp"
                android:gravity="center"
                android:text="☆"
                android:textColor="#D8A46B"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/star3"
                android:layout_width="52dp"
                android:layout_height="58dp"
                android:gravity="center"
                android:text="☆"
                android:textColor="#D8A46B"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/star4"
                android:layout_width="52dp"
                android:layout_height="58dp"
                android:gravity="center"
                android:text="☆"
                android:textColor="#D8A46B"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/star5"
                android:layout_width="52dp"
                android:layout_height="58dp"
                android:gravity="center"
                android:text="☆"
                android:textColor="#D8A46B"
                android:textSize="46sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/ratingLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to rate"
            android:textColor="#D8A46B"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- DETAILS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Coffee Details"
            android:textColor="#FFF3E5"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="36dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginTop="14dp"
            android:background="#241B17">

            <TextView
                android:id="@+id/detailsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E8D7CE"
                android:textSize="15sp"
                android:textStyle="bold"
                android:lineSpacingExtra="8dp" />
        </LinearLayout>

        <!-- TASTE PROFILE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. Taste Profile"
            android:textColor="#FFF3E5"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="36dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginTop="14dp"
            android:background="#241B17">

            <TextView
                android:text="Rate the key taste attributes of your coffee."
                android:textColor="#BFAFA8"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:text="Sweetness"
                android:textColor="#FFF3E5"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <SeekBar
                android:id="@+id/sweetnessSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#D8A46B"
                android:thumbTint="#D8A46B"
                android:progressBackgroundTint="#4B3A33"
                android:max="10"
                android:progress="5" />

            <TextView
                android:text="Bitterness"
                android:textColor="#FFF3E5"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <SeekBar
                android:id="@+id/bitternessSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#D8A46B"
                android:thumbTint="#D8A46B"
                android:progressBackgroundTint="#4B3A33"
                android:max="10"
                android:progress="4" />

            <TextView
                android:text="Acidity"
                android:textColor="#FFF3E5"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <SeekBar
                android:id="@+id/aciditySeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#D8A46B"
                android:thumbTint="#D8A46B"
                android:progressBackgroundTint="#4B3A33"
                android:max="10"
                android:progress="6" />

            <TextView
                android:text="Body"
                android:textColor="#FFF3E5"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <SeekBar
                android:id="@+id/bodySeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#D8A46B"
                android:thumbTint="#D8A46B"
                android:progressBackgroundTint="#4B3A33"
                android:max="10"
                android:progress="7" />
        </LinearLayout>

        <!-- FLAVOR NOTES -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4. Flavor Notes"
            android:textColor="#FFF3E5"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="36dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select the flavors you tasted."
            android:textColor="#BFAFA8"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:layout_marginTop="14dp">

            <TextView
                android:id="@+id/chocolateChip"
                android:text="☕ Chocolate"
                style="@style/ReviewChip" />

            <TextView
                android:id="@+id/caramelChip"
                android:text="🍯 Caramel"
                style="@style/ReviewChip" />

            <TextView
                android:id="@+id/nuttyChip"
                android:text="🌰 Nutty"
                style="@style/ReviewChip" />

            <TextView
                android:id="@+id/fruityChip"
                android:text="🍓 Fruity"
                style="@style/ReviewChip" />

            <TextView
                android:id="@+id/floralChip"
                android:text="🌸 Floral"
                style="@style/ReviewChip" />

            <TextView
                android:id="@+id/citrusChip"
                android:text="🍊 Citrus"
                style="@style/ReviewChip" />
        </GridLayout>

        <!-- REVIEW -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5. Your Review"
            android:textColor="#FFF3E5"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="36dp" />

        <EditText
            android:id="@+id/reviewInput"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="14dp"
            android:gravity="top"
            android:hint="Write your thoughts about this coffee..."
            android:padding="16dp"
            android:textColor="#FFF3E5"
            android:textColorHint="#BFAFA8"
            android:textStyle="bold"
            android:background="#3A211B" />

        <!-- RECOMMEND -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="6. Would you recommend this coffee?"
            android:textColor="#FFF3E5"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="36dp" />

        <SeekBar
            android:id="@+id/recommendSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:progress="8"
            android:layout_marginTop="12dp" />

        <!-- SAVE BUTTON -->
        <Button
            android:id="@+id/saveReviewButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Save Review"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2A1713"
            android:backgroundTint="#D8A46B"
            android:layout_marginTop="36dp" />

    </LinearLayout>
</ScrollView>
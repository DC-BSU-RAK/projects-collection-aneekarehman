<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2A1713"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="42dp"
        android:paddingBottom="50dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/back_button"
                android:scaleType="fitCenter"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Coffee Details"
                android:textColor="#FFE8A3"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/favoriteButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="♡"
                android:textColor="#FFE8A3"
                android:textSize="38sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="255dp"
            android:layout_marginTop="18dp">

            <LinearLayout
                android:layout_width="185dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/categoryLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="All Drinks"
                    android:textColor="#5A321F"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/productName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Latte"
                    android:textColor="#FFA000"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/productDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:text="Smooth espresso blended with creamy milk."
                    android:textColor="#D9A54C"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/productImage"
                android:layout_width="170dp"
                android:layout_height="170dp"
                android:layout_gravity="end|center_vertical"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Size Options:"
                android:textColor="#E8D7CE"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Approx*"
                android:textColor="#8F2416"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:columnCount="2">

            <LinearLayout
                android:id="@+id/smallSize"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☕"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:text="Small"
                    android:textColor="#F5E6D3"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="8 oz  -  235ml"
                    android:textColor="#D8C3B4"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mediumSize"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☕"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:text="Medium"
                    android:textColor="#F5E6D3"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="12 oz  -  345ml"
                    android:textColor="#D8C3B4"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/largeSize"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☕"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:text="Large"
                    android:textColor="#F5E6D3"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="16 oz  -  470ml"
                    android:textColor="#D8C3B4"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/xlSize"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☕"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:text="Extra Large"
                    android:textColor="#F5E6D3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="20 oz  -  590ml"
                    android:textColor="#D8C3B4"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="💳 Price:"
            android:textColor="#E8D7CE"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/priceInput"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:hint="Type here"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#2A1713"
            android:textColorHint="#9A3A31"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="🏪 Cafe / Store:"
            android:textColor="#E8D7CE"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/storeInput"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:hint="Type here"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#2A1713"
            android:textColorHint="#9A3A31"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Milk Options:"
            android:textColor="#E8D7CE"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:columnCount="2">

            <TextView
                android:id="@+id/wholeMilk"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:text="🥛\n\nWhole Milk\nRich &amp; Creamy"
                android:textColor="#E8D7CE"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/oatMilk"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:text="🥛\n\nOat Milk\nSmooth &amp; Sweet"
                android:textColor="#E8D7CE"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/almondMilk"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:text="🥛\n\nAlmond Milk\nLight &amp; Nutty"
                android:textColor="#E8D7CE"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/soyMilk"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:text="🥛\n\nSoy Milk\nCreamy &amp; Mild"
                android:textColor="#E8D7CE"
                android:textSize="14sp"
                android:textStyle="bold" />
        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Sweetness Level:"
            android:textColor="#E8D7CE"
            android:textSize="18sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/sweetnessSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:progress="5" />

        <TextView
            android:id="@+id/sweetnessText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Medium Sweet"
            android:textColor="#FFE8A3"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Brew Method:"
            android:textColor="#E8D7CE"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:columnCount="2">

            <TextView
                android:id="@+id/espressoMachine"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:text="☕\n\nEspresso Machine\nFast &amp; Bold"
                android:textColor="#E8D7CE"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/frenchPress"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:text="☕\n\nFrench Press\nRich &amp; Manual"
                android:textColor="#E8D7CE"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dripMachine"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:text="☕\n\nDrip Machine\nSmooth &amp; Classic"
                android:textColor="#E8D7CE"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pourOver"
                android:layout_width="0dp"
                android:layout_height="165dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:gravity="center"
                android:text="☕\n\nPour Over Set\nClean &amp; Precise"
                android:textColor="#E8D7CE"
                android:textSize="14sp"
                android:textStyle="bold" />
        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Best Paired With:"
            android:textColor="#E8D7CE"
            android:textSize="18sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/pairCroissant"
                    android:layout_width="155dp"
                    android:layout_height="180dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="125dp"
                        android:layout_height="95dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/croissant" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Croissant"
                        android:textColor="#8F2416"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pairChocolateCroissant"
                    android:layout_width="155dp"
                    android:layout_height="180dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="125dp"
                        android:layout_height="95dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/chocolatecroissant" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Chocolate Croissant"
                        android:textColor="#8F2416"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pairPancakes"
                    android:layout_width="155dp"
                    android:layout_height="180dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="125dp"
                        android:layout_height="95dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/pancakes" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Pancakes"
                        android:textColor="#8F2416"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pairBagels"
                    android:layout_width="155dp"
                    android:layout_height="180dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="125dp"
                        android:layout_height="95dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/bagels" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Bagels"
                        android:textColor="#8F2416"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pairSalad"
                    android:layout_width="155dp"
                    android:layout_height="180dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="125dp"
                        android:layout_height="95dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/salad" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Salad"
                        android:textColor="#8F2416"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <Button
            android:id="@+id/enterReviewButton"
            android:layout_width="250dp"
            android:layout_height="62dp"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:text="Enter Review"
            android:textAllCaps="false"
            android:textColor="#8F2416"
            android:textSize="24sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
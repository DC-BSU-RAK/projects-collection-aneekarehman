<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2A1713">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="22dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/backButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="←"
                android:textColor="#FFE8A3"
                android:textSize="34sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="App Settings"
                android:textColor="#FFE8A3"
                android:textSize="40sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginTop="18dp" />

            <!-- NOTIFICATIONS -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textColor="#FFE8A3"
                android:textSize="22sp"
                android:layout_marginTop="26dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/center_button_bg"
                android:backgroundTint="#3A241F">

                <Switch
                    android:id="@+id/reviewReminderSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Review Reminders\nRemind me to review coffees."
                    android:textColor="#FFF3E5"
                    android:textSize="16sp" />

                <Switch
                    android:id="@+id/newFeaturesSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="New Features\nNotify me about app updates."
                    android:textColor="#FFF3E5"
                    android:textSize="16sp"
                    android:layout_marginTop="18dp" />
            </LinearLayout>

            <!-- CAFE ALERTS -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cafe Alerts"
                android:textColor="#FFE8A3"
                android:textSize="24sp"
                android:layout_marginTop="30dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/center_button_bg"
                android:backgroundTint="#3A241F">

                <Switch
                    android:id="@+id/dealsSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Favorite Cafe Deals\nAlerts about cafe deals."
                    android:textColor="#FFF3E5"
                    android:textSize="16sp" />

                <Switch
                    android:id="@+id/nearbySwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nearby Coffee Shops\nShow nearby cafe suggestions."
                    android:textColor="#FFF3E5"
                    android:textSize="16sp"
                    android:layout_marginTop="18dp" />
            </LinearLayout>

            <!-- REVIEW MANAGEMENT -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Review Management"
                android:textColor="#FFE8A3"
                android:textSize="24sp"
                android:layout_marginTop="30dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/center_button_bg"
                android:backgroundTint="#3A241F">

                <Switch
                    android:id="@+id/autoSaveSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Auto-Save Reviews\nAutomatically save reviews."
                    android:textColor="#FFF3E5"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/clearHistoryButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:text="Clear Review History   ›"
                    android:textColor="#FFF3E5"
                    android:textSize="17sp"
                    android:layout_marginTop="18dp" />

                <TextView
                    android:id="@+id/exportReviewsButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:text="Export Reviews   ›"
                    android:textColor="#FFF3E5"
                    android:textSize="17sp" />
            </LinearLayout>

            <!-- SAVE BUTTON -->

            <Button
                android:id="@+id/saveChangesButton"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Save Changes"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginTop="60dp"
                android:backgroundTint="#D8A46B" />

            <TextView
                android:id="@+id/backHomeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Back to Home"
                android:textColor="#D8A46B"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="40dp" />
        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="82dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/nav_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/homeNav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="#FFFFFF" />

            <TextView
                android:text="Home"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/discoverNav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search"
                app:tint="#FFFFFF" />

            <TextView
                android:text="Discover"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/activityNav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_notifications"
                app:tint="#FFFFFF" />

            <TextView
                android:text="Activity"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/settingsNav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                app:tint="#D8A46B" />

            <TextView
                android:text="Settings"
                android:textColor="#D8A46B"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
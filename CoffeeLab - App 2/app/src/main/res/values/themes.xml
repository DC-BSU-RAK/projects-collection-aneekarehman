<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.CoffeeLabApp2" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/quicksand_variable</item>
        <item name="fontFamily">@font/quicksand_variable</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textViewStyle">@style/BoldTextView</item>
        <item name="buttonStyle">@style/BoldButton</item>
        <item name="editTextStyle">@style/BoldEditText</item>
    </style>

    <style name="BoldTextView" parent="Widget.AppCompat.TextView">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BoldButton" parent="Widget.Material3.Button">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BoldEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Theme.CoffeeLabApp2" parent="Base.Theme.CoffeeLabApp2" />

    <style name="ReviewChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">40dp</item>

        <item name="android:layout_margin">6dp</item>

        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>

        <item name="android:gravity">center</item>

        <item name="android:textColor">#FFF3E5</item>
        <item name="android:textSize">13sp</item>

        <item name="android:fontFamily">@font/quicksand_variable</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>